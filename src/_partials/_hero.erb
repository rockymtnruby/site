<div class="clouds-wrapper" style="position: absolute; width: 100%; overflow-x: visible; ">
  <div id="cloud1" class="cloud"></div>
  <div id="cloud2" class="cloud"></div>
  <div id="cloud3" class="cloud"></div>
</div>
<div id="sky">
  <div class="text-block">
    <h1>Rocky Mountain Ruby</h1>
    <p class="mt-1 text-center"><time datetime="2026-09-28" class="hero-date">Monday, September 28th and Tuesday, September 29th 2026</time></p>
    <p class="mt-4 text-center">A two day, single track conference in the heart of Boulder, Colorado.</p>
    <p class="mt-3 text-center text-white">
      Catch up on last year: <a href="https://2025.rockymtnruby.dev/" target="_blank" class="underline">2025 program</a> and <a href="https://www.youtube.com/watch?v=eK0YK5y4fOo&list=PLE7tQUdRKcyZWRurElt80vkH4wuisnUBq" target="_blank" class="underline">videos</a>.
    </p>
    <div class="mt-6 pb-4 flex flex-col items-center gap-4">
      <% if site.metadata.cfp_open %>
        <a href="#cfp" class="hero-cfp-banner hero-cfp-banner--active" aria-label="Call for Papers: May 15 to June 30, 2026. Submit a proposal.">
          <p class="hero-cfp-banner__eyebrow">Call for Papers</p>
          <p class="hero-cfp-banner__dates">May 15 &ndash; June 30, 2026</p>
          <p class="hero-cfp-banner__cta">Submit a Proposal &rarr;</p>
        </a>
      <% else %>
        <div class="hero-cfp-banner hero-cfp-banner--passive" aria-label="Call for Papers opens May 15, 2026">
          <p class="hero-cfp-banner__eyebrow">Call for Papers</p>
          <p class="hero-cfp-banner__dates">Opens May 15, 2026</p>
        </div>
      <% end %>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <div class="hero-cta-card hero-cta-card--passive" aria-label="Tickets status: coming soon">
          <p class="font-semibold">Tickets Coming Soon</p>
        </div>
        <a href="/sponsorship" class="hero-cta-card hero-cta-card--link">
          <p class="font-semibold">Sponsor Us</p>
          <p class="text-sm hero-cta-sub">Help make it happen &rarr;</p>
        </a>
      </div>
    </div>
  </div>
  <img src="/assets/images/hero/mountains.svg" alt="" class="front-mountains" />
</div>
<section class="mountain-text-section parallax_group">
  <div class="mountain-text-content">
    <h4 class="text-white leading-tight">An intimate single-track Ruby conference in Boulder, Colorado — good talks, real conversations, and the kind of hallway track you actually remember.</h4>
  </div>
  <div class="parallax__layer--back layer">
    &nbsp;
  </div>
</section>
<div id="trees" class="parallax_group">
  <div class="parallax__layer--fore layer">
  </div>
  <div class="parallax__layer--back layer">
    &nbsp;
  </div>
  <div class="parallax__layer--base layer">
    &nbsp;
  </div>
</div>
<section class="why-rmr" id="why">
  <div class="why-rmr-content">
    <h1>Why Rocky Mountain Ruby?</h1>
    <h3>Good talks combined with plenty of time for the "hallway" track.</h3>
  </div>
  <img src="/assets/images/hero/triangle-down-speckles.svg" class="w-full" alt="" />
</section>
<section class="features">
  <div class="container">
    <dl class="features-grid">
      <div class="feature-card">
        <dt>An Intimate Conference</dt>
        <dd>Engage in meaningful conversations and build strong connections in the Ruby community.</dd>
      </div>
      <div class="feature-card">
        <dt>Community</dt>
        <dd>Join the welcoming Ruby community of Boulder and the Colorado Front Range. No matter your background or skill level, if you love working with Ruby, you'll belong.</dd>
      </div>
      <div class="feature-card">
        <dt>In the Heart of it All</dt>
        <dd>Right in downtown Boulder, a few minutes walk from the famous Pearl Street Mall you'll have easy access to hiking, biking, and all of the Colorado great outdoors.</dd>
      </div>
      <div class="feature-card">
        <dt>Open Lunch</dt>
        <dd>Lunch will be open. We'll provide a long break so you can explore Boulder's amazing food scene. And we'll help you meet new people to enjoy it with.</dd>
      </div>
    </dl>
  </div>
</section>
<img src="/assets/images/hero/triangle-up-speckles.svg" class="w-full" alt="" />
<script type="text/javascript">
    gsap.to("#cloud1", {
        scrollTrigger: {
            trigger: "#cloud1",
            start: "top center",
            toggleActions: "restart pause reverse pause",
            // markers: true,
            scrub: 3,
        },
        x: "-20vw", // Reduced from -25vw to keep more in viewport
        duration: 5,
    });
    gsap.to("#cloud2", {
        scrollTrigger: {
            trigger: "#cloud2",
            start: "top center",
            toggleActions: "restart pause reverse pause",
            // markers: true,
            scrub: 3,
        },
        x: "10vw", // Reduced from 15vw to prevent overflow
        duration: 3,
    });
    gsap.to("#cloud3", {
        scrollTrigger: {
            trigger: "#cloud3",
            start: "top center",
            toggleActions: "restart pause reverse pause",
            // markers: true,
            scrub: 1,
        },
        x: "-15vw", // Changed from -200px to viewport units
        duration: 10,
    });

